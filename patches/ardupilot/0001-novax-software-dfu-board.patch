diff --git a/Tools/AP_Bootloader/AP_Bootloader.cpp b/Tools/AP_Bootloader/AP_Bootloader.cpp
index 951eee3092..15b9558ff4 100644
--- a/Tools/AP_Bootloader/AP_Bootloader.cpp
+++ b/Tools/AP_Bootloader/AP_Bootloader.cpp
@@ -27,6 +27,7 @@
 #include "hwdef.h"
 #include <AP_HAL_ChibiOS/hwdef/common/usbcfg.h>
 #include <AP_HAL_ChibiOS/hwdef/common/stm32_util.h>
+#include <AP_HAL_ChibiOS/hwdef/common/flash.h>
 #include <AP_HAL_ChibiOS/hwdef/common/watchdog.h>
 #include "support.h"
 #include "bl_protocol.h"
@@ -74,6 +75,30 @@ int main(void)
 
     flash_init();
 
+#if defined(STM32H7)
+    // Post-DFU self-heal: auto-boot the app after a USB-DFU flash with NO power cycle.
+    // The ST ROM DfuSe "leave" (and CubeProgrammer --start) is a JUMP to 0x08000000, not a
+    // system reset -- it lands here in the bootloader while BOOT_ADD0 still points at the ROM
+    // system bootloader (0x1FF0, set by Util::boot_to_dfu on DFU entry) and leaves the USB OTG
+    // core in the ROM's dirty state (dark: the host never sees a disconnect/re-enumerate). A
+    // jump also never re-samples BOOT_ADD0. So restore the cold-boot address to 0x08000000 and
+    // issue a real SYSRESETREQ: the ROM re-latches BOOT_ADD0=0x0800 and cold-boots us with a
+    // clean OTG core, and the app enumerates USB without an unplug. This is the exact inverse
+    // of Util::boot_to_dfu(). It fires ONLY on the post-DFU jump; a normal cold boot already has
+    // BOOT_CUR==0x0800 so this is a no-op. A committed-readback guard prevents a boot loop if
+    // the option write fails.
+    if ((FLASH->BOOT_CUR & 0xFFFFU) == 0x1FF0U) {
+        const uint32_t bootcur = stm32_flash_set_boot_address0(0x08000000);
+        if ((bootcur & 0xFFFFU) == 0x0800U) {
+            RCC->AHB1ENR &= ~(RCC_AHB1ENR_USB1OTGHSEN | RCC_AHB1ENR_USB2OTGFSEN);
+            __DSB();
+            NVIC_SystemReset();
+            while (true) {}
+        }
+        // option write did not commit: fall through and run the bootloader normally.
+    }
+#endif
+
 #if AP_FLASH_ECC_CHECK_ENABLED
     check_ecc_errors();
 #endif
diff --git a/libraries/AP_HAL_ChibiOS/Util.cpp b/libraries/AP_HAL_ChibiOS/Util.cpp
index 1012216b02..ba09d58434 100644
--- a/libraries/AP_HAL_ChibiOS/Util.cpp
+++ b/libraries/AP_HAL_ChibiOS/Util.cpp
@@ -827,9 +827,40 @@ void* Util::last_crash_dump_ptr() const
 #if HAL_ENABLE_DFU_BOOT && !defined(HAL_BOOTLOADER_BUILD)
 void Util::boot_to_dfu()
 {
+#if defined(STM32H7)
+    // H7/H753 buttonless DFU via option-byte COLD-BOOT (verified on-bench: 0483:df11
+    // enumerates). A software jump to the ST system bootloader (0x1FF09800) leaves USB dark
+    // on this silicon, so instead commit the cold-boot address BOOT_ADD0=0x1FF00000 and
+    // system-reset: the ROM then boots fresh into USB DFU exactly like a BOOT0-high power-on
+    // (RM0433 sec 2.6/8.4.2: BOOT_ADDx is re-latched on every system reset, not POR-only).
+    // Option bytes are NOT reloaded by a soft reset, so BOOT_ADD0 must be committed BEFORE
+    // the reset; clear the USB OTG clocks first so USB state cannot leak across it (ST
+    // td-p/148186). Only reset if the commit actually took (readback low half == 0x1FF0);
+    // otherwise restore 0x08000000 and keep running the app, so a failed write is never a
+    // strand. The DFU host restores BOOT_ADD0=0x08000000 after flashing (else every reset
+    // re-enters ROM DFU; recoverable via SWD or USB-DFU option write, not a brick).
+    const uint32_t bootcur = stm32_flash_set_boot_address0(0x1FF00000);
+    if ((bootcur & 0xFFFFU) != 0x1FF0U) {
+        stm32_flash_set_boot_address0(0x08000000);   // restore; keep running the app
+        return;
+    }
+    RCC->AHB1ENR &= ~(RCC_AHB1ENR_USB1OTGHSEN | RCC_AHB1ENR_USB2OTGFSEN);
+    __DSB();
+    NVIC_SystemReset();
+    while (true) {}
+#else
     hal.util->persistent_data.boot_to_dfu = true;
     stm32_watchdog_save((uint32_t *)&hal.util->persistent_data, (sizeof(hal.util->persistent_data)+3)/4);
+#if HAL_USE_SERIAL_USB == TRUE
+    // F4/F7: signal a USB disconnect (drop D+) before the reset so the host releases the stale
+    // CDC handle and re-enumerates the ST ROM DFU device that comes back — a bare reset leaves
+    // D+ pulled up and the ROM DFU never enumerates ("dark"). Verified on novaX_F405. (H7 takes
+    // the BOOT_ADD0 cold-boot branch above, which resets USB-OTG cleanly, so it does not need this.)
+    usbDisconnectBus(&USBD1);
+    chThdSleepMilliseconds(50);
+#endif
     hal.scheduler->reboot();
+#endif
 }
 #endif
 
diff --git a/libraries/AP_HAL_ChibiOS/hwdef/common/board.c b/libraries/AP_HAL_ChibiOS/hwdef/common/board.c
index 618fe597ac..170b1d53aa 100644
--- a/libraries/AP_HAL_ChibiOS/hwdef/common/board.c
+++ b/libraries/AP_HAL_ChibiOS/hwdef/common/board.c
@@ -234,6 +234,78 @@ static void stm32_gpio_init(void) {
  * You can rely on: 1) const variables or tables 2) flash code 3) automatic variables
  */
 void __early_init(void) {
+#if defined(HAL_BOOTLOADER_BUILD) && HAL_ENABLE_DFU_BOOT && !defined(STM32H7)
+  /* novaX F4/F7 software-DFU jump. H7 is EXCLUDED here: on H753 this bootloader jump leaves
+     USB dark, so H7 instead enters DFU via the option-byte BOOT_ADD0 cold-boot and the
+     AP_Bootloader self-heal auto-boot (see Util::boot_to_dfu() and AP_Bootloader.cpp main()).
+     Gating H7 out keeps the H7E bootloader binary unchanged by this patch.
+     ArduPilot's DFU-boot jump normally lives in AP_HAL_ChibiOS/system.cpp
+     __entry_hook(), which upstream relies on ChibiOS crt0 to call via CRT0_ENTRY_HOOK. This
+     tree's ChibiOS crt0 (commit 88b8460) lacks that hook, and __entry_hook() also can't be
+     resolved across archives at link time (libch.a -> libAP_Bootloader_libs.a back-ref). So
+     the bootloader never honoured the boot_to_dfu flag (MAVLink param4=99 / "Entering DFU
+     mode") and software DFU was impossible. Implement the jump inline here: __early_init runs
+     from crt0 before any other init, the correct early point. Layout mirrors
+     AP_HAL::Util::PersistentData (same compiler/flags, no -fshort-enums => identical layout);
+     we only need the trailing boot_to_dfu flag, persisted in RTC backup block 1. */
+  {
+      struct dfu_persistent_data {
+          float roll_rad, pitch_rad, yaw_rad;
+          int32_t home_lat, home_lon, home_alt_cm;
+          uint32_t fault_addr, fault_icsr, fault_lr, internal_errors;
+          uint16_t internal_error_count, internal_error_last_line;
+          uint32_t spi_count, i2c_count, i2c_isr_count;
+          uint16_t waypoint_num, last_mavlink_msgid, last_mavlink_cmd, semaphore_line, fault_line;
+          uint8_t fault_type, fault_thd_prio;
+          char thread_name4[4];
+          int8_t scheduler_task;
+          uint8_t armed;
+          uint8_t safety_state;   /* enum safety_state : uint8_t (1 byte!) */
+          uint8_t boot_to_dfu;
+      } pd;
+      stm32_watchdog_load((uint32_t *)&pd, (sizeof(pd)+3)/4);
+      if (pd.boot_to_dfu) {
+#if defined(STM32F4) || defined(STM32F7)
+          /* __early_init runs before stm32_clock_init, so the PWR clock and backup-domain
+             write-enable (DBP) are not set up yet. Reading RTC backup works, but WRITING
+             (the clear below) silently fails without them — so boot_to_dfu never clears and
+             the board re-enters DFU on every boot (stuck loop). Enable PWR clock + DBP here. */
+          RCC->APB1ENR |= RCC_APB1ENR_PWREN; (void)RCC->APB1ENR;
+          PWR->CR |= PWR_CR_DBP;
+#endif
+          pd.boot_to_dfu = 0;
+          stm32_watchdog_save((uint32_t *)&pd, (sizeof(pd)+3)/4);
+          /* Full deinit before jumping to the ST ROM system bootloader so its USB enumerates.
+             A bare MSP+jump leaves IRQs/SysTick/VTOR from the AP bootloader's crt0 in place,
+             which breaks the ROM USB ("device descriptor request failed"). Sequence per the
+             canonical jump-to-system-memory guides (ST community / stm32world). */
+          __disable_irq();
+          SysTick->CTRL = 0; SysTick->LOAD = 0; SysTick->VAL = 0;
+          for (unsigned _i = 0; _i < 8U; _i++) { NVIC->ICER[_i] = 0xFFFFFFFFu; NVIC->ICPR[_i] = 0xFFFFFFFFu; }
+          __enable_irq();
+          /* ST ROM system-bootloader base differs per family (AN2606):
+             F4=0x1FFF0000, F7=0x1FF00000, H7=0x1FF09800. */
+#if defined(STM32H7)
+          const uint32_t _sysmem = 0x1FF09800;
+#elif defined(STM32F7)
+          const uint32_t _sysmem = 0x1FF00000;
+#else
+          const uint32_t _sysmem = 0x1FFF0000;  /* STM32F4 */
+          /* F4: map system flash to 0x00000000 (SYSCFG_MEMRMP MEM_MODE=0b01) */
+          RCC->APB2ENR |= RCC_APB2ENR_SYSCFGEN; (void)RCC->APB2ENR;
+          SYSCFG->MEMRMP = (SYSCFG->MEMRMP & ~0x3u) | 0x1u;
+#endif
+          const uint32_t *app_base = (const uint32_t *)_sysmem;
+          SCB->VTOR = _sysmem;
+          __DSB(); __ISB();
+          __set_MSP(app_base[0]);
+          __set_CONTROL(0);
+          __ISB();
+          ((void (*)(void))(app_base[1]))();
+          while (1);
+      }
+  }
+#endif
 #if !defined(STM32F1)
   stm32_gpio_init();
 #endif
diff --git a/libraries/AP_HAL_ChibiOS/hwdef/common/flash.c b/libraries/AP_HAL_ChibiOS/hwdef/common/flash.c
index 3fa4f73e24..b7b206f3b0 100644
--- a/libraries/AP_HAL_ChibiOS/hwdef/common/flash.c
+++ b/libraries/AP_HAL_ChibiOS/hwdef/common/flash.c
@@ -1165,6 +1165,90 @@ void stm32_flash_set_NRST_MODE(uint8_t nrst_mode)
 }
 #endif // HAL_FLASH_SET_NRST_MODE
 
+#if defined(STM32H7)
+/*
+  set the Cortex-M7 cold-boot address (BOOT_ADD0, used when BOOT0 is low) in the
+  option bytes. Used for buttonless DFU on H7: point the cold boot at the ST
+  system bootloader (0x1FF00000) so a reset enters ROM USB DFU exactly like a
+  BOOT0-high power-on, then have the DFU host restore 0x08000000 after flashing.
+  A software jump to the system bootloader leaves USB dark on this H753 silicon, so
+  the cold-boot option-byte route is used instead. Follows the RM0433 option-byte
+  programming procedure (both banks idle -> unlock -> OPTSTART -> verify).
+ */
+uint32_t stm32_flash_set_boot_address0(uint32_t addr)
+{
+    const uint32_t add0 = (addr >> 16) & 0xFFFFU;                  // BOOT_ADD0 = addr[31:16]
+    const uint32_t prg = (FLASH->BOOT_CUR & 0xFFFF0000U) | add0;   // keep BOOT_ADD1
+    if (prg == FLASH->BOOT_CUR) {
+        return FLASH->BOOT_CUR; // already set
+    }
+    // option-byte write sequence (self-contained: the static opt helpers above are
+    // compiled only under HAL_FLASH_PROTECTION/HAL_FLASH_SET_NRST_MODE). Mirrors the
+    // proven WPSN/PRAR path: BOTH-BANK wait_idle -> clear errors -> OPT unlock ->
+    // stage PRG -> re-check idle -> OPTSTART -> poll OPT_BUSY -> verify -> OPT lock.
+    __DSB();
+    // STEP 1 (RM0433): an option change is silently ignored while EITHER bank has a
+    // pending program/erase or a queued/undrained write. A running app writes flash
+    // (params/storage/logging), so we MUST wait on SR1/SR2 (BSY|QW|WBNE) -- not just
+    // OPTSR_CUR.OPT_BUSY -- or OPTSTART never launches and BOOT_ADD0 stays 0x0800.
+    // (This is exactly what the halted CubeProgrammer/ST-Link avoids.) Same flags as
+    // stm32_flash_wait_idle() above.
+    while ((FLASH->SR1 & (FLASH_SR_BSY|FLASH_SR_QW|FLASH_SR_WBNE))
+#if STM32_FLASH_NBANKS > 1
+           || (FLASH->SR2 & (FLASH_SR_BSY|FLASH_SR_QW|FLASH_SR_WBNE))
+#endif
+          ) { /* wait for both banks idle */ }
+    while (FLASH->OPTSR_CUR & FLASH_OPTSR_OPT_BUSY) { /* wait opt engine idle */ }
+    // STEP 3: clear stale main-flash (CCR1/CCR2) and option (OPTCCR) errors, only
+    // AFTER the interface is quiescent so a latched error can't re-arm through OPTSTART.
+    FLASH->CCR1 = ~0U;
+#if STM32_FLASH_NBANKS > 1
+    FLASH->CCR2 = ~0U;
+#endif
+    FLASH->OPTCCR = FLASH_OPTCCR_CLR_OPTCHANGEERR;
+    __DSB();
+    // STEP 2: unlock ONLY the option registers (main-flash KEYR unlock not required).
+    if (FLASH->OPTCR & FLASH_OPTCR_OPTLOCK) {
+        FLASH->OPTKEYR = FLASH_OPTKEY1;
+        FLASH->OPTKEYR = FLASH_OPTKEY2;
+        __DSB(); __ISB();
+    }
+    if (FLASH->OPTCR & FLASH_OPTCR_OPTLOCK) {
+        return 0xE0000002U; // option unlock failed
+    }
+    if (FLASH->OPTSR_CUR & FLASH_OPTSR_OPTCHANGEERR) {
+        return 0xE0000001U; // stale option change error, refuse to launch
+    }
+    // STEP 4: stage the new boot address into the shadow (PRG) register.
+    FLASH->BOOT_PRG = prg;
+    __DSB();
+    // Re-confirm both banks are still idle immediately before launch (a writer could
+    // have queued a bank write during the unlock window).
+    while ((FLASH->SR1 & (FLASH_SR_BSY|FLASH_SR_QW|FLASH_SR_WBNE))
+#if STM32_FLASH_NBANKS > 1
+           || (FLASH->SR2 & (FLASH_SR_BSY|FLASH_SR_QW|FLASH_SR_WBNE))
+#endif
+          ) { /* wait for both banks idle */ }
+    // STEP 5: launch. OPT_BUSY asserts within a few flash-clocks if accepted.
+    FLASH->OPTCR |= FLASH_OPTCR_OPTSTART;
+    __DSB(); __ISB();
+    // STEP 6: wait for the self-timed option NVM write to complete.
+    while (FLASH->OPTSR_CUR & FLASH_OPTSR_OPT_BUSY) { /* wait program done */ }
+    // STEP 7: verify the change actually committed.
+    if (FLASH->OPTSR_CUR & FLASH_OPTSR_OPTCHANGEERR) {
+        FLASH->OPTCCR = FLASH_OPTCCR_CLR_OPTCHANGEERR;
+        FLASH->OPTCR |= FLASH_OPTCR_OPTLOCK;
+        __DSB();
+        return 0xE0000003U; // option change rejected after launch
+    }
+    // STEP 8: re-lock option registers (only after OPT_BUSY cleared).
+    FLASH->OPTCR |= FLASH_OPTCR_OPTLOCK;
+    __DSB();
+    // New BOOT_ADD0 is latched at the next reset/POR (no OBL_LAUNCH on H743/H753).
+    return FLASH->BOOT_CUR; // committed value; the caller checks the readback
+}
+#endif // STM32H7
+
