diff --git a/libraries/AP_HAL_ChibiOS/Util.cpp b/libraries/AP_HAL_ChibiOS/Util.cpp
index 1012216b02..e33ee0b91a 100644
--- a/libraries/AP_HAL_ChibiOS/Util.cpp
+++ b/libraries/AP_HAL_ChibiOS/Util.cpp
@@ -829,6 +829,14 @@ void Util::boot_to_dfu()
 {
     hal.util->persistent_data.boot_to_dfu = true;
     stm32_watchdog_save((uint32_t *)&hal.util->persistent_data, (sizeof(hal.util->persistent_data)+3)/4);
+#if HAL_USE_SERIAL_USB == TRUE
+    // Signal a USB disconnect (pull D+ low) and hold it before the reset, so the host sees
+    // the CDC device go away and re-enumerates whatever comes back — the ST ROM DFU. A bare
+    // soft jump leaves D+ pulled up, so the host keeps the stale COM handle and the ROM DFU
+    // never enumerates (board appears "dark"). Verified failure mode on novaX_F405.
+    usbDisconnectBus(&USBD1);
+    chThdSleepMilliseconds(50);
+#endif
     hal.scheduler->reboot();
 }
 #endif
